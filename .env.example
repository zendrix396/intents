# Solana RPC endpoint (required)
# Get one from https://www.helius.dev/ or https://quicknode.com
RPC_URL=https://api.devnet.solana.com

# Wallet key (one of these is required)
# Option 1: BIP39 seed phrase
SEED_PHRASE=your twelve word seed phrase here

# Option 2: Base58 private key (alternative to seed phrase)
# PRIVATE_KEY=your_base58_private_key_here

# Server bind address (optional, default: 0.0.0.0:3000)
# BIND_ADDR=0.0.0.0:3000

# CORS allowed origin (optional, default: allow all origins)
# Set to your frontend URL for production deployments
# ALLOWED_ORIGIN=http://localhost:3001
